# ============================================================
# Zero Trust Platform — Environment Variables
# Copy this file to .env and fill in the values
# cp .env.example .env
# ============================================================

# RabbitMQ
RABBITMQ_USER=
RABBITMQ_PASS=

# Redis
REDIS_PASS=

# PostgreSQL
POSTGRESQL_USER=
POSTGRESQL_PASS=
POSTGRES_DB=

# MongoDB
MONGODB_USER=
MONGODB_PASS=

# MinIO
MINIO_USER=
MINIO_PASS=

# JWT 
JWT_SECRET=                  # min 32 characters, use: openssl rand -hex 32

# Mailtrap
MAILTRAP_USER=
MAILTRAP_PASSWORD=
